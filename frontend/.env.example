# Copy to .env.local for local development (never commit .env.local)
# In production, set these in Vercel → Project Settings → Environment Variables

# ── Backend URL ───────────────────────────────────────────────────────────────
VITE_API_URL=https://your-render-backend.onrender.com

# ── Clerk (Auth) ─────────────────────────────────────────────────────────────
# Get from: clerk.com → your app → API Keys
# Publishable key is safe for frontend
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# ── Supabase (Database) ───────────────────────────────────────────────────────
# Get from: supabase.com → your project → Project Settings → API
# Use the PUBLISHABLE (anon) key on the frontend — RLS restricts what it can access
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_supabase_publishable_key_here

# ── Polar (Payments) ──────────────────────────────────────────────────────────
# Get from: polar.sh → your org → Products → (each product) → Share / Checkout link
# Leave blank to keep the tier button disabled ("Coming soon").
VITE_POLAR_URL_STARTER=https://buy.polar.sh/your-starter-pack-url
VITE_POLAR_URL_PREP=https://buy.polar.sh/your-prep-pack-url
VITE_POLAR_URL_STUDIO=https://buy.polar.sh/your-studio-subscription-url
