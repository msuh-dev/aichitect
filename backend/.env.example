# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secret keys.

# ── Anthropic ────────────────────────────────────────────────────────────────
# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AI provider:
#   mock  → instant hardcoded response, zero API cost (use for frontend development)
#   claude → real Claude API call (use for prompt testing and production)
AI_PROVIDER=mock

# Claude model (only used when AI_PROVIDER=claude):
#   claude-haiku-4-5-20251001  → cheapest, fast (free tier designs)
#   claude-sonnet-4-6          → best quality (paid tier designs)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Clerk (Auth) ─────────────────────────────────────────────────────────────
# Get from: clerk.com → your app → API Keys
# Secret key is backend-only — never expose to frontend
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# ── Supabase (Database) ───────────────────────────────────────────────────────
# Get from: supabase.com → your project → Project Settings → API
# Use the SECRET key on the backend (bypasses RLS — backend is trusted)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your_supabase_secret_key_here

# ── Credits ───────────────────────────────────────────────────────────────────
# Admin accounts — bypasses all credit checks
# Comma-separated for multiple: ADMIN_EMAILS=alice@example.com,bob@example.com
ADMIN_EMAILS=michaelsuh87@gmail.com

# Free tier monthly allowance (designs per month for unauthenticated / free users)
FREE_DESIGNS_PER_MONTH=3

# ── Polar (Payments) ──────────────────────────────────────────────────────────
# Get from: polar.sh → your org → Settings → Webhooks → your endpoint → Secret
# Used to verify that webhook payloads genuinely come from Polar.
POLAR_WEBHOOK_SECRET=whsec_your_polar_webhook_secret_here
